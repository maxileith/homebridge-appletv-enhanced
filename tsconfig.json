{
    "compilerOptions": {
        "target": "es2025",
        "lib": ["DOM", "ES2025"],
        "rootDir": "src",
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "skipLibCheck": true,
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "sourceMap": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "resolveJsonModule": true,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": ["src/"],
    "exclude": ["**/*.spec.ts"]
}
